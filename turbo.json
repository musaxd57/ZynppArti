{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "ANTHROPIC_API_KEY",
        "OPENAI_API_KEY",
        "AKASHML_API_KEY",
        "OPENAI_IMAGE_MODEL",
        "NEXT_PUBLIC_COLLAB_WS",
        "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
        "CLERK_SECRET_KEY",
        "DATABASE_URL"
      ]
    },
    "test": {},
    "lint": {},
    "typecheck": {}
  }
}
